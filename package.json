{
  "name": "biome-bunx-formatter",
  "displayName": "Biome (bunx) Formatter",
  "description": "Format files using bunx @biomejs/biome",
  "version": "0.0.1",
  "publisher": "vladstudio",
  "engines": { "vscode": "^1.75.0" },
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:json",
    "onLanguage:jsonc",
    "onLanguage:css",
    "onLanguage:html",
    "onLanguage:vue",
    "onLanguage:svelte",
    "onLanguage:astro",
    "onLanguage:graphql",
    "onLanguage:yaml"
  ],
  "scripts": {
    "compile": "tsc -p ."
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.75.0",
    "typescript": "^5.0.0"
  }
}
