{
  "name": "biome-bunx-formatter",
  "displayName": "Biome (bunx) Formatter",
  "description": "Format files with Biome via bunx — no local install required.",
  "version": "0.0.1",
  "publisher": "vladstudio",
  "license": "MIT",
  "icon": "icon.png",
  "categories": ["Formatters"],
  "keywords": ["biome", "formatter", "bun", "bunx", "biomejs"],
  "repository": {
    "type": "git",
    "url": "https://github.com/vladstudio/biome.git"
  },
  "engines": { "vscode": "^1.75.0" },
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:json",
    "onLanguage:jsonc",
    "onLanguage:css",
    "onLanguage:html",
    "onLanguage:vue",
    "onLanguage:svelte",
    "onLanguage:astro",
    "onLanguage:graphql",
    "onLanguage:yaml"
  ],
  "scripts": {
    "compile": "tsc -p ."
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.75.0",
    "typescript": "^5.0.0"
  }
}
